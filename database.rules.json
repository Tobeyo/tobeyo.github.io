{
  "rules": {
    "autoswap": {
      ".read": true,
      ".write": true,
      "currentDriver": {
        ".validate": "newData.isString() && (newData.val() === 'Tobias' || newData.val() === 'Daniel')"
      },
      "lastSwapDate": {
        ".validate": "newData.isString()"
      },
      "dayAssignments": {
        "$date": {
          ".validate": "newData.hasChildren(['driver'])",
          "driver": {
            ".validate": "newData.isString() && (newData.val() === 'Tobias' || newData.val() === 'Daniel')"
          },
          "time": {
            ".validate": "newData.isString()"
          }
        }
      },
      "swapHistory": {
        "$index": {
          ".validate": "newData.hasChildren(['from', 'to', 'date'])"
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
